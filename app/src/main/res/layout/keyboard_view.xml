<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="34dp"
        android:scrollbars="none" android:paddingStart="6dp" android:paddingEnd="6dp">
        <LinearLayout android:id="@+id/modeTabs" android:layout_width="wrap_content"
            android:layout_height="match_parent" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingTop="4dp" android:paddingBottom="4dp"/>
    </HorizontalScrollView>

    <HorizontalScrollView android:id="@+id/acScrollView" android:layout_width="match_parent"
        android:layout_height="36dp" android:scrollbars="none"
        android:paddingStart="6dp" android:paddingEnd="6dp">
        <LinearLayout android:id="@+id/acStrip" android:layout_width="wrap_content"
            android:layout_height="match_parent" android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <HorizontalScrollView android:id="@+id/scScroll" android:layout_width="match_parent"
        android:layout_height="28dp" android:scrollbars="none"
        android:paddingStart="6dp" android:paddingEnd="6dp" android:visibility="gone">
        <LinearLayout android:id="@+id/scBar" android:layout_width="wrap_content"
            android:layout_height="match_parent" android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/kwGrid"
        android:layout_width="match_parent" android:layout_height="200dp"
        android:padding="5dp" android:clipToPadding="false"
        android:overScrollMode="never" android:visibility="gone"/>

    <LinearLayout android:id="@+id/alphaKb" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="5dp" android:visibility="gone">
        <LinearLayout android:id="@+id/numRow" android:layout_width="match_parent"
            android:layout_height="34dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/alphaRow1" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/alphaRow2" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/alphaRow3" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/alphaBottomRow" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="2dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/symKb" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="5dp" android:visibility="gone">
        <LinearLayout android:id="@+id/symRow1" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/symRow2" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/symRow3" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/symRow4" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="4dp"/>
        <LinearLayout android:id="@+id/symBottomRow" android:layout_width="match_parent"
            android:layout_height="46dp" android:orientation="horizontal" android:layout_marginBottom="2dp"/>
    </LinearLayout>

    <ScrollView android:id="@+id/templateScroll" android:layout_width="match_parent"
        android:layout_height="250dp" android:visibility="gone">
        <LinearLayout android:id="@+id/templateList" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp"/>
    </ScrollView>

    <LinearLayout android:id="@+id/settingsPanel" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="10dp" android:visibility="gone" android:minHeight="250dp"/>

</LinearLayout>
